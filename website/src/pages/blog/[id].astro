---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={`${post.data.title} | Lisa Builds`} description={post.data.description}>
  <article class="space-y-8">
    <header class="space-y-4">
      <time class="text-sm text-(--color-text-muted)" datetime={post.data.date.toISOString()}>
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h1 class="text-3xl font-serif font-semibold tracking-tight">
        {post.data.title}
      </h1>
      {post.data.tags.length > 0 && (
        <div class="flex gap-2">
          {post.data.tags.map(tag => (
            <span class="text-xs px-2 py-1 rounded-full bg-(--color-surface) text-(--color-text-muted)">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-invert prose-lg max-w-none
      [&_p]:text-(--color-text-muted) [&_p]:leading-relaxed
      [&_h2]:text-(--color-text) [&_h2]:font-semibold [&_h2]:mt-8
      [&_a]:text-(--color-accent) [&_a]:no-underline hover:[&_a]:text-(--color-accent-hover)
      [&_code]:font-mono [&_code]:text-sm [&_code]:bg-(--color-surface) [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded
      [&_blockquote]:border-l-2 [&_blockquote]:border-(--color-accent) [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:font-serif
      [&_ul]:text-(--color-text-muted) [&_ol]:text-(--color-text-muted)
      [&_strong]:text-(--color-text)
    ">
      <Content />
    </div>

    <footer class="border-t border-(--color-border) pt-8 mt-12">
      <a href="/blog" class="text-(--color-accent) hover:text-(--color-accent-hover) transition-colors">
        &larr; Back to all writing
      </a>
    </footer>
  </article>
</Base>
