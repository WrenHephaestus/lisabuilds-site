---
import Base from '../layouts/Base.astro';
---

<Base title="Tools | Wren Builds">
  <div class="space-y-8">
    <h1 class="text-3xl font-serif font-semibold tracking-tight">Tools</h1>
    <p class="text-(--color-text-muted) leading-relaxed">
      Things I've built. All focused on making AI tools work better for solo developers.
    </p>

    <div class="space-y-8 pt-4">
      <div class="border border-(--color-border) rounded-lg p-6 space-y-3">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-semibold">The Claude Code Playbook</h2>
          <span class="text-sm text-(--color-accent)">$9</span>
        </div>
        <p class="text-(--color-text-muted) leading-relaxed">
          12 CLAUDE.md templates for different project types. 7 workflow patterns
          for common development scenarios. A memory management guide. Power user
          tips. A prompt cheatsheet. Everything I know about making Claude Code
          actually useful, in one place.
        </p>
        <a
          href="https://lisahephaestus.gumroad.com/l/zhmvdh"
          class="inline-block mt-2 px-4 py-2 bg-(--color-accent) text-white rounded font-medium text-sm hover:bg-(--color-accent-hover) transition-colors"
        >
          Get it on Gumroad
        </a>
      </div>

      <div class="border border-(--color-border) rounded-lg p-6 space-y-3">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-semibold">claudemd</h2>
          <span class="text-sm text-(--color-text-muted)">Free / Open Source</span>
        </div>
        <p class="text-(--color-text-muted) leading-relaxed">
          CLI tool that scans your project for languages, frameworks, and structure,
          then generates a tailored CLAUDE.md through interactive prompts. Detects
          20+ languages and frameworks, suggests "Do NOT" rules from real developer
          pain points, and outputs a structured file in 60 seconds.
        </p>
        <div class="flex gap-3 mt-2">
          <code class="text-sm font-mono bg-(--color-surface) px-3 py-1 rounded text-(--color-text-muted)">
            npx claudemd
          </code>
          <span class="text-sm text-(--color-text-muted) self-center">v0.1 &middot; coming soon to npm</span>
        </div>
      </div>
    </div>
  </div>
</Base>
