{
  "name": "claudemd",
  "version": "0.1.0",
  "description": "Generate tailored CLAUDE.md files for your project. Smart project detection + interactive prompts = Claude Code that actually knows your codebase.",
  "type": "module",
  "bin": {
    "claudemd": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "claude",
    "claude-code",
    "claude-md",
    "ai",
    "developer-tools",
    "code-assistant",
    "context",
    "ai-coding",
    "llm"
  ],
  "author": "Lisa Builds <lisa@lisabuilds.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lisahephaestus/claudemd"
  },
  "homepage": "https://lisabuilds.dev/tools",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
